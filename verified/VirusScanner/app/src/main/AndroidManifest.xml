<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:hasCode="true"
        android:label="Thor App & APK Antivirus"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">

        <!-- Tells Thor Core which class implements the contract -->
        <meta-data
            android:name="thor.extension.class"
            android:value="com.valhalla.thor.ext.antivirus.VirusScannerExtension" />
        <meta-data
            android:name="thor.extension.api.version"
            android:value="2" />

        <!-- Config store for secure IPC with Thor Core -->
        <provider
            android:name=".provider.AntivirusConfigProvider"
            android:authorities="com.valhalla.thor.ext.antivirus.configprovider"
            android:exported="true" />

        <!-- Configuration UI, launched by Thor via the CONFIGURE action. Runs in THIS app's own
             process (own Compose/Asgard) so no runtime types cross into Thor. Must be exported for
             Thor (a different app) to start it. -->
        <activity
            android:name=".ConfigActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:label="Thor App & APK Antivirus"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
            <intent-filter>
                <action android:name="com.valhalla.thor.extension.action.CONFIGURE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

    </application>
</manifest>
