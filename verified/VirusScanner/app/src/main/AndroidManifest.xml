<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:hasCode="true"
        android:label="S.H.I.E.L.D."
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">

        <!-- Tells Thor Core which class implements the contract -->
        <meta-data
            android:name="thor.extension.class"
            android:value="com.valhalla.thor.ext.antivirus.VirusScannerExtension" />
        <meta-data
            android:name="thor.extension.api.version"
            android:value="2" />

        <!-- Config store for secure IPC with Thor Core -->
        <provider
            android:name=".provider.AntivirusConfigProvider"
            android:authorities="com.valhalla.thor.ext.antivirus.configprovider"
            android:exported="true" />

        <!-- Background security scanning service -->
        <service
            android:name=".AntivirusScanService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="On-device virus/security file scanning" />
        </service>

        <!-- Configuration UI, launched by Thor via the CONFIGURE action. Runs in THIS app's own
             process (own Compose/Asgard) so no runtime types cross into Thor. Must be exported for
             Thor (a different app) to start it. -->
        <activity
            android:name=".ConfigActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:label="S.H.I.E.L.D."
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="com.valhalla.thor.extension.action.CONFIGURE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

    </application>
</manifest>
